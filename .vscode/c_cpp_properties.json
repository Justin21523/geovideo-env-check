{
  "version": 4,
  "configurations": [
    {
      "name": "CMake Debug",
      "compileCommands": "${workspaceFolder}/compile_commands.json",
      "compilerPath": "/usr/bin/c++",
      "cppStandard": "c++20",
      "intelliSenseMode": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/include"
        ],
        "databaseFilename": "${workspaceFolder}/build/.vscode-browse.vc.db"
      },
      "forcedInclude": []
    }
  ]
}
